# NFM-Eval-Harness-delivery — slim INL handoff repo .gitignore
# The venv and third-party components are NOT vendored. setup-*.sh reproduces them:
# lm_eval is installed via pip (uv pip install "lm_eval[hf,vllm]==0.4.12"); gsma-evals
# is an optional reference clone (not a runtime dependency). On the build host .venv
# (and any optional reference clones) may be symlinks from the engineering-source repo.

# venv + optional third-party reference clones (gitignored; never committed).
# No trailing slash: these may be symlinks (not dirs), so a trailing-slash pattern
# would NOT match them and they would get tracked. Match both symlink + dir.
# lm-evaluation-harness is kept as a harmless guard in case it is cloned for source
# reference; the runtime install is via pip, so it is normally absent.
.venv
lm-evaluation-harness
gsma-evals

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# OMC / agent scratch + editors (never ship to a public repo)
.omc/
.omx/
.claude*
.DS_Store
.idea/

# Ephemeral working outputs (not part of the delivery bundle)
outputs/

# setup-*.sh generated artifacts (local only)
version-dep.txt
version-vllm-check.log
.cache_hf
cuda_*.run

# eval results: keep curated final evidence (results/final/**: results_*.json + *.md)
# tracked, but never commit large per-sample dumps or raw logs.
results/**/*_samples_*.jsonl
results/**/samples_*.jsonl
results/**/*.log
results/**/*.tmp
results/smoke-*/
results/conf-*/

# overnight orchestrator ephemera (keep results_*.json + _aggregate.json)
results/final/_status.json
results/final/_logs/
results/final/**/_aggregate.md
